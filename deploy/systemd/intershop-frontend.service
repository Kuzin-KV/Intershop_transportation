[Unit]
Description=Intershop Transportation Frontend Preview
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/intershop/cross-platform-logistics-system
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run preview -- --host 127.0.0.1 --port 4173
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
